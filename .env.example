# ── Required ────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
INDIAN_KANOON_API_KEY=your_kanoon_api_key_here   # free at indiankanoon.org

# ── Optional fallback LLM (leave blank unless you have a real key) ─────────────
ANTHROPIC_API_KEY=

# ── Storage paths ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/caseminds.db
CHROMA_PERSIST_DIR=./data/chroma
GRAPH_PATH=./data/graph.pkl
BM25_PATH=./data/bm25.pkl

# ── Pipeline thresholds ──────────────────────────────────────────────────────
MIN_RETRIEVAL_SCORE=0.30
VERIFICATION_THRESHOLD=0.50
VERIFICATION_MIN_VERIFIED=1

# ── Deployment (optional) ────────────────────────────────────────────────────
# Required to seed corpus on Render free tier (Shell is paid-only). Use:
#   curl -X POST "https://YOUR-APP.onrender.com/api/v1/admin/seed?demo=true" \
#     -H "X-Admin-Secret: YOUR_VALUE_HERE"
SEED_ADMIN_SECRET=

# ── App config ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
